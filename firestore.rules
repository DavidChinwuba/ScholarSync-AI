// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required)
//   - displayName: string (optional)
//   - email: string (required)
//   - photoURL: string (optional)
//   - stats: map (optional)
//   - createdAt: timestamp (required)
//
// Collection: flashcardSets
// Document ID: {setId}
// Fields:
//   - userId: string (required)
//   - title: string (required)
//   - topic: string (required)
//   - cards: list (required)
//   - createdAt: timestamp (required)
//
// Collection: quizzes
// Document ID: {quizId}
// Fields:
//   - userId: string (required)
//   - title: string (required)
//   - questions: list (required)
//   - createdAt: timestamp (required)
//
// Collection: studyGroups
// Document ID: {groupId}
// Fields:
//   - name: string (required)
//   - topic: string (required)
//   - createdBy: string (required)
//   - members: list (optional)
//   - createdAt: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string &&
             data.email.size() < 100;
    }

    function isValidFlashcardSet(data) {
      return data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.cards is list && data.cards.size() <= 50;
    }

    function isValidQuiz(data) {
      return data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.questions is list && data.questions.size() <= 20;
    }

    function isValidStudyGroup(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.topic is string && data.topic.size() < 100;
    }

    function isAdmin() {
      return isAuthenticated() && (request.auth.token.email == "nkchuba@gmail.com" && request.auth.token.email_verified == true);
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /flashcardSets/{setId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidFlashcardSet(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidFlashcardSet(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /quizzes/{quizId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidQuiz(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidQuiz(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /studySchedules/{scheduleId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid);
    }

    match /userTokens/{userId} {
      allow read: if isOwner(userId);
      // Write is only allowed from server (Admin SDK)
      allow write: if false;
    }

    match /studyGroups/{groupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidStudyGroup(request.resource.data);
      allow update: if isAuthenticated(); // Simplified for member joining
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    match /revenue/{docId} {
      allow read: if isAuthenticated(); // Allow reading for dashboard (admin check in UI)
      allow create: if isAdmin();
      allow update: if isAuthenticated(); // Simplified for now, will use increment in code
    }

    match /homeworkChats/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
